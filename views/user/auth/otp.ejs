<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/izitoast/dist/css/iziToast.min.css">
    <script src="https://cdn.jsdelivr.net/npm/izitoast/dist/js/iziToast.min.js"></script>
    <script src="/js/toast.js"></script>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts for modern typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <style>
        /* Glassmorphism setup */
        .glass-input {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.05);
        }
        
        .glass-input:focus {
            background: rgba(255, 255, 255, 0.25);
            border-color: rgba(255, 255, 255, 0.6);
            outline: none;
        }

        /* Prevent autofill style changes */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active{
            -webkit-box-shadow: 0 0 0 30px transparent inset !important;
            -webkit-text-fill-color: white !important;
            transition: background-color 5000s ease-in-out 0s;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden bg-[#57A507]">
    <!-- Background Gradient -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_#93E326_0%,_#65B60A_45%,_#3A8302_100%)]"></div>

    <div class="relative z-10 w-full max-w-md px-6 flex flex-col items-center mt-[-40px]">
        <!-- Title area -->
        <div class="text-center mb-6">
            <h1 class="text-white text-[42px] leading-tight font-medium tracking-tight">Verify the</h1>
            <h2 class="text-white text-[52px] leading-tight font-bold tracking-tight">shared OTP</h2>
        </div>

        <!-- Description -->
        <p class="text-center text-white/90 text-[15px] font-medium leading-relaxed mb-10">
            we have shared a 4-digit otp to your entered<br>
            email id
        </p>

        <!-- OTP Input fields -->
        <div class="flex items-center justify-center gap-4 mb-8 w-full" id="otp-container">
            <input type="text" maxlength="1"  class="glass-input w-[85px] h-[140px] rounded-[45px] text-center text-[44px] font-semibold text-white transition-all duration-300">
            <input type="text" maxlength="1"  class="glass-input w-[85px] h-[140px] rounded-[45px] text-center text-[44px] font-semibold text-white transition-all duration-300">
            <input type="text" maxlength="1"  class="glass-input w-[85px] h-[140px] rounded-[45px] text-center text-[44px] font-semibold text-white transition-all duration-300">
            <input type="text" maxlength="1"  class="glass-input w-[85px] h-[140px] rounded-[45px] text-center text-[44px] font-semibold text-white transition-all duration-300">
        </div>

        <!-- Success Match Text -->
        <div class="flex items-center justify-center gap-2 mb-16">
            
            <span class="text-white text-[14px] font-medium tracking-wide">Enter passcode</span>
        </div>
    </div>

    <!-- Bottom Actions -->
    <div class="absolute bottom-12 left-0 w-full text-center z-10 flex flex-col gap-3">
        <button id="resendBtn" class="text-white/70 hover:text-white text-[13px] font-medium transition-colors cursor-pointer bg-transparent border-none">
            didn't receive code? Click to Resend - <span id="timer">00:30</span>
        </button>
        <button class="text-white/50 hover:text-white/80 text-[13px] font-medium transition-colors cursor-pointer bg-transparent border-none">
            Go back to Sign in
        </button>
    </div>

    <!-- Simple Interactivity for OTP Inputs -->
    <script>
        showSuccess("Otp will be shared soon..")
        const timerElement = document.getElementById('timer');
        const resendBtn = document.getElementById('resendBtn');

        let timeLeft = 30; // seconds

        const formatTime = (time) => {
            const minutes = Math.floor(time / 60);
            const seconds = time % 60;
            return `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
        };

        const countdown = () => {
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                timerElement.textContent = "00:00";
                resendBtn.textContent = "Click to Resend otp";
                resendBtn.disabled = false;
                return;
            }

            timerElement.textContent = formatTime(timeLeft);
            timeLeft--;
        };

        // Disable button initially
        resendBtn.disabled = true;


        const getOtpValue = () => {
            return Array.from(inputs).map(input => input.value).join('');
        };

        const verifyOtpRequest = async (otp)=>{

            try{
                const token = sessionStorage.getItem("token")

                const request = await fetch("/auth/otp",{
                    method:"POST",
                    headers:{
                        "Content-Type":"application/json"
                    },
                    body:JSON.stringify({
                        token,
                        otp
                    })
                })

                const result = await request.json()

                if(!result.success){
                    showError(result.message)
                    return;
                }

                window.location.href = result.redirect

            }catch(err){

                showError(err.message)

            }
        }

        const timerInterval = setInterval(countdown, 1000);
        const inputs = document.querySelectorAll('#otp-container input');
        
        inputs.forEach((input, index) => {
            // Auto Select value on focus for quicker editing
            input.addEventListener('focus', () => {
                input.select();
            });

            input.addEventListener('input', (e) => {
                // Focus next input when value is entered
                if (e.target.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                
                const otp = getOtpValue()
                if(otp.length == inputs.length&& !otp.includes(" ")){
                    
                    verifyOtpRequest(otp)
                }
            });
            
            input.addEventListener('keydown', (e) => {
                // Move back when backspace is pressed on empty input
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        
    </script>
</body>
</html>
