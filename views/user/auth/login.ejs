<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zipp Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/izitoast/dist/css/iziToast.min.css">
    <script src="https://cdn.jsdelivr.net/npm/izitoast/dist/js/iziToast.min.js"></script>
    <script src="/js/toast.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0b0c10;
            color: white;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .glow-bg {
            background: radial-gradient(circle at top left, #1fbc55 0%, #0b0c10 60%);
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center p-6">
    <div class="max-w-6xl w-full grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">

        <!-- Left Panel -->
        <div
            class="glow-bg rounded-[2.5rem] p-10 flex flex-col justify-center relative overflow-hidden h-full min-h-[600px]">
            <div class="relative z-10 max-w-sm mx-auto w-full">
                <div class="flex items-center justify-center gap-2 mb-10">
                    <div
                        class="w-10 h-10 rounded-full bg-green-500 relative flex items-center justify-center overflow-hidden">
                        <!-- Logo icon pseudo-element -->
                        <div class="absolute w-[120%] border-t-[4px] border-black transform -rotate-45"></div>
                    </div>
                    <span class="text-4xl font-bold tracking-widest text-white">Zipp.</span>
                </div>

                <h1 class="text-4xl text-center font-bold mb-4 text-white">Get started with us</h1>
                <p class="text-gray-300 text-center mb-12 text-sm">Complete these easy steps to register your account.
                </p>

                <div class="relative border-l border-gray-600/50 pl-8 ml-4 space-y-6">
                    <!-- Step 1 -->
                    <div class="relative">
                        <div
                            class="absolute -left-[2.4rem] w-3 h-3 rounded-full border-2 border-gray-500 bg-[#0b0c10] top-5">
                        </div>
                        <div
                            class="bg-[#15171d]/60 border border-gray-700/50 rounded-2xl p-5 hover:bg-[#15171d] transition duration-300">
                            <h3 class="text-lg font-medium mb-1 flex items-center gap-2">
                                <span>✏️</span> Sign up your account
                            </h3>
                            <p class="text-xs text-gray-400">Complete these easy steps to register your account.</p>
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div class="relative">
                        <div
                            class="absolute -left-[2.4rem] w-3 h-3 rounded-full border-2 border-gray-500 bg-[#0b0c10] top-5">
                        </div>
                        <div
                            class="bg-[#15171d]/60 border border-gray-700/50 rounded-2xl p-5 hover:bg-[#15171d] transition duration-300">
                            <h3 class="text-lg font-medium mb-1 flex items-center gap-2">
                                <span>🔍</span> Create your account
                            </h3>
                            <p class="text-xs text-gray-400">Complete these easy steps to register your account.</p>
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div class="relative">
                        <div
                            class="absolute -left-[2.4rem] w-3 h-3 rounded-full border-2 border-gray-500 bg-[#0b0c10] top-5">
                        </div>
                        <div
                            class="bg-[#15171d]/60 border border-gray-700/50 rounded-2xl p-5 hover:bg-[#15171d] transition duration-300">
                            <h3 class="text-lg font-medium mb-1 flex items-center gap-2">
                                <span>🎉</span> Start your ride with Zipp
                            </h3>
                            <p class="text-xs text-gray-400">Complete these easy steps to register your account.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel - Login Form -->
        <div class="flex flex-col justify-center px-4 lg:px-12 py-8 max-w-md w-full mx-auto">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-semibold mb-2">Sign in to Zipp</h2>
                <p class="text-gray-400 text-sm">Enter your data to Sign in your account.</p>
            </div>

            <div class="flex gap-4 mb-8">
                <button
                    class="flex-1 flex items-center justify-center gap-2 border border-gray-800 rounded-xl p-3 hover:bg-gray-900 transition text-xs font-medium">
                    <svg class="w-4 h-4" viewBox="0 0 24 24">
                        <path
                            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                            fill="#4285F4" />
                        <path
                            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            fill="#34A853" />
                        <path
                            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                            fill="#FBBC05" />
                        <path
                            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                            fill="#EA4335" />
                    </svg>
                    Sign up with Google
                </button>
                <button
                    class="flex-1 flex items-center justify-center gap-2 border border-gray-800 rounded-xl p-3 hover:bg-gray-900 transition text-xs font-medium">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.04 2.26-.74 3.58-.74 2.14 0 3.86 1 4.7 2.45-3.9 2.1-3.26 7.4.88 8.94-1.07 1.81-2.23 3.45-4.24 1.52M12.03 6.4c-.2-2.31 1.76-4.22 3.96-4.4.31 2.5-2.12 4.47-3.96 4.4z" />
                    </svg>
                    Sign up with Apple
                </button>
            </div>

            <div class="relative flex py-4 items-center mb-6 gap-4">
                <div class="flex-grow border-t border-gray-800"></div>
                <span class="flex-shrink-0 text-gray-500 text-xs">Or</span>
                <div class="flex-grow border-t border-gray-800"></div>
            </div>

            <form class="space-y-5" id="login-form">
                <div>
                    <label class="block text-xs font-medium text-gray-300 mb-2">Email Address</label>
                    <input type="email" id="email" value="Sarahw12@mail.com"
                        class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 focus:bg-[#131418] transition text-sm text-gray-300">
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-300 mb-2">Password</label>
                    <div class="relative">
                        <input type="password" id="password" value="Sarahw12@mail.com"
                            class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 focus:bg-[#131418] transition text-sm text-gray-300 pr-10">
                        <button type="button"
                            class="absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-500 hover:text-gray-300">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between pt-2">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <div class="w-4 h-4 rounded-full bg-green-500 flex items-center justify-center">
                            <svg class="w-2.5 h-2.5 text-black" fill="none" stroke="currentColor" stroke-width="3"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <span class="text-xs text-white">Remember me</span>
                        <input type="checkbox" class="hidden" checked>
                    </label>
                    <a href="#" class="text-xs text-gray-400 hover:text-white transition">Forget Password?</a>
                </div>

                <div class="pt-2">
                    <button type="submit"
                        class="w-full bg-[#1fbc55] hover:bg-green-600 text-black font-semibold rounded-xl py-3.5 transition duration-300 shadow-[0_0_15px_rgba(31,188,85,0.2)] mt-2">
                        Sign up
                    </button>
                </div>
            </form>

            <div class="text-center mt-6">
                <p class="text-xs text-gray-500">Do you have an account ? <a href="#"
                        class="text-white hover:underline ml-1 font-medium">Sign up</a></p>
            </div>
        </div>
    </div>
</body>

<script>

    //LOGIN FORM FOR ZIPP

    document.getElementById('login-form').addEventListener("submit",handleLogin)
    function handleLogin(e){
        e.preventDefault()
        const email = document.getElementById('email').value.trim()
        const password = document.getElementById('password').value.trim()
        if(!email||!password){
             showError("Invalid email or password");
        }
        
        try{

        }catch(e){
            showError("Something went wrong. Try again.")
            console.error("\n\n Unexpected error occure on Zipp!!! \n\n",e)
        }
    }
</script>

</html>