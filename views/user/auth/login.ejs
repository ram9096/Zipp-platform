<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zipp Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/izitoast/dist/css/iziToast.min.css">
    <script src="https://cdn.jsdelivr.net/npm/izitoast/dist/js/iziToast.min.js"></script>
    <script src="/js/toast.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/zod@3.23.8/lib/index.umd.min.js"></script>
    <style>
        body {
            background-color: #0b0c10;
            color: white;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .glow-bg {
            background: radial-gradient(circle at top left, #1fbc55 0%, #0b0c10 60%);
        }

        /* Role card selection */
        .role-card {
            cursor: pointer;
            border: 2px solid transparent;
            background: #131418;
            border-radius: 1rem;
            padding: 1.25rem;
            transition: all 0.25s ease;
            position: relative;
            overflow: hidden;
        }
        .role-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top left, rgba(31,188,85,0.08) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .role-card:hover::before { opacity: 1; }
        .role-card:hover { border-color: rgba(31,188,85,0.4); }
        .role-card.selected {
            border-color: #57A507;
            background: #0f1f14;
            box-shadow: 0 0 20px rgba(31,188,85,0.15);
        }
        .role-card.selected::before { opacity: 1; }
        .role-card .check {
            display: none;
        }
        .role-card.selected .check {
            display: flex;
        }

        /* Form transition */
        .form-section {
            animation: fadeSlideIn 0.3s ease;
        }
        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center p-6 ">
    <div class="max-w-6xl w-full grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">

        <!-- Left Panel -->
        <div class="rounded-[2.5rem] p-10 flex flex-col justify-center relative overflow-hidden h-full min-h-[600px]"
            style="background: radial-gradient(ellipse at 0% 0%,#57A507 0%, #0b0c10 55%);">

            <!-- Decorative rings -->
            <div class="absolute -top-16 -left-16 w-56 h-56 rounded-full border border-green-500/10"></div>
            <div class="absolute -top-8 -left-8 w-36 h-36 rounded-full border border-green-500/15"></div>

            <div class="relative z-10 max-w-sm mx-auto w-full">

                <!-- Logo -->
                <div class="flex items-center justify-center gap-2.5 mb-10">
                    <div class="w-9 h-9 rounded-full bg-green-500 relative flex items-center justify-center overflow-hidden">
                        <div class="absolute w-[130%] border-t-[3.5px] border-black transform -rotate-45"></div>
                    </div>
                    <span class="text-3xl font-bold tracking-widest text-white">Zipp.</span>
                </div>

                <!-- Heading -->
                <h1 class="text-[1.6rem] text-center font-bold mb-2 text-white leading-snug">Get started with us</h1>
                <p class="text-center mb-10 text-xs text-white/40 leading-relaxed">A few simple steps and you're on your way.</p>

                <!-- Steps -->
                <div class="flex flex-col gap-3">

                    <!-- Step 1 — Active -->
                    <div class="flex items-start gap-4 bg-white/[0.04] border border-white/[0.07] rounded-[1.25rem] p-4">
                        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-green-500/10 border border-green-500/25 flex items-center justify-center mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="#1fbc55" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-white mb-0.5">Sign up your account</p>
                            <p class="text-[0.72rem] text-white/40 leading-relaxed">Choose your role and fill in your details.</p>
                        </div>
                        <span class="flex-shrink-0 self-center text-[0.65rem] font-semibold text-green-400 bg-green-500/10 border border-green-500/20 rounded-full px-2.5 py-0.5">01</span>
                    </div>

                    <!-- Step 2 -->
                    <div class="flex items-start gap-4 bg-white/[0.04] border border-white/[0.07] rounded-[1.25rem] p-4">
                        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-white/70 mb-0.5">Verify your identity</p>
                            <p class="text-[0.72rem] text-white/35 leading-relaxed">Quick verification to keep everyone safe.</p>
                        </div>
                        <span class="flex-shrink-0 self-center text-[0.65rem] font-semibold text-white/30 bg-white/5 border border-white/8 rounded-full px-2.5 py-0.5">02</span>
                    </div>

                    <!-- Step 3 -->
                    <div class="flex items-start gap-4 bg-white/[0.04] border border-white/[0.07] rounded-[1.25rem] p-4">
                        <div class="flex-shrink-0 w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-white/70 mb-0.5">Start riding with Zipp</p>
                            <p class="text-[0.72rem] text-white/35 leading-relaxed">You're all set — enjoy the ride.</p>
                        </div>
                        <span class="flex-shrink-0 self-center text-[0.65rem] font-semibold text-white/30 bg-white/5 border border-white/8 rounded-full px-2.5 py-0.5">03</span>
                    </div>

                </div>

                <!-- Trust line -->
                <div class="mt-8 pt-6 border-t border-white/[0.07] flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="#1fbc55" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    <p class="text-[0.7rem] text-white/35">Your data is encrypted and never shared.</p>
                </div>

            </div>
        </div>

        <!-- Right Panel -->
        <div class="flex flex-col justify-center px-4 lg:px-12 py-8 max-w-md w-full mx-auto">

            <!-- ===== LOGIN VIEW ===== -->
            <div id="view-login" class="form-section">
                <div class="text-center mb-8">
                    <h2 class="text-3xl font-semibold mb-2">Sign in to Zipp</h2>
                    <p class="text-gray-400 text-sm">Enter your data to Sign in your account.</p>
                </div>

                <div class="flex gap-4 mb-8">
                    <button class="flex-1 flex items-center justify-center gap-2 border border-gray-800 rounded-xl p-3 hover:bg-gray-900 transition text-xs font-medium">
                        <svg class="w-4 h-4" viewBox="0 0 24 24">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                        Sign in with Google
                    </button>
                    <button class="flex-1 flex items-center justify-center gap-2 border border-gray-800 rounded-xl p-3 hover:bg-gray-900 transition text-xs font-medium">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.04 2.26-.74 3.58-.74 2.14 0 3.86 1 4.7 2.45-3.9 2.1-3.26 7.4.88 8.94-1.07 1.81-2.23 3.45-4.24 1.52M12.03 6.4c-.2-2.31 1.76-4.22 3.96-4.4.31 2.5-2.12 4.47-3.96 4.4z"/>
                        </svg>
                        Sign in with Apple
                    </button>
                </div>

                <div class="relative flex py-4 items-center mb-6 gap-4">
                    <div class="flex-grow border-t border-gray-800"></div>
                    <span class="flex-shrink-0 text-gray-500 text-xs">Or</span>
                    <div class="flex-grow border-t border-gray-800"></div>
                </div>

                <form class="space-y-5" id="login-form">
                    <div>
                        <label class="block text-xs font-medium text-gray-300 mb-2">Email Address</label>
                        <input type="email" id="email" value="Sarahw12@mail.com"
                            class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 transition text-sm text-gray-300">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-300 mb-2">Password</label>
                        <div class="relative">
                            <input type="password" id="password" value="Sarahw12@mail.com"
                                class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 transition text-sm text-gray-300 pr-10">
                            <button type="button" class="absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-500 hover:text-gray-300">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="flex items-center justify-between pt-2">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <div class="w-4 h-4 rounded-full bg-green-500 flex items-center justify-center">
                                <svg class="w-2.5 h-2.5 text-black" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </div>
                            <span class="text-xs text-white">Remember me</span>
                            <input type="checkbox" class="hidden" checked>
                        </label>
                        <a href="#" class="text-xs text-gray-400 hover:text-white transition">Forget Password?</a>
                    </div>
                    <div class="pt-2">
                        <button type="submit" class="w-full bg-[#1fbc55] hover:bg-green-600 text-black font-semibold rounded-xl py-3.5 transition duration-300 shadow-[0_0_15px_rgba(31,188,85,0.2)] mt-2">
                            Sign in
                        </button>
                    </div>
                </form>

                <div class="text-center mt-6">
                    <p class="text-xs text-gray-500">Don't have an account?
                        <a href="#" id="go-to-role-select" class="text-white hover:underline ml-1 font-medium">Sign up</a>
                    </p>
                </div>
            </div>

            <!-- ===== ROLE SELECTION VIEW ===== -->
            <div id="view-role" class="form-section hidden">
                <div class="text-center mb-8">
                    <h2 class="text-3xl font-semibold mb-2">Join Zipp as…</h2>
                    <p class="text-gray-400 text-sm">Choose how you'd like to use Zipp.</p>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-8">
                    <!-- Rider Card -->
                    <div class="role-card" id="card-rider" onclick="selectRole('rider')">
                        <div class="check w-5 h-5 rounded-full bg-green-500 items-center justify-center absolute top-3 right-3">
                            <svg class="w-3 h-3 text-black" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                        </div>
                        <div class="text-4xl mb-3">🧍</div>
                        <h3 class="text-base font-semibold text-white mb-1">Rider</h3>
                        <p class="text-xs text-gray-400 leading-relaxed">Book rides quickly and get to your destination safely.</p>
                    </div>

                    <!-- Driver Card -->
                    <div class="role-card" id="card-driver" onclick="selectRole('driver')">
                        <div class="check w-5 h-5 rounded-full bg-green-500 items-center justify-center absolute top-3 right-3">
                            <svg class="w-3 h-3 text-black" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                        </div>
                        <div class="text-4xl mb-3">🚗</div>
                        <h3 class="text-base font-semibold text-white mb-1">Driver</h3>
                        <p class="text-xs text-gray-400 leading-relaxed">Earn on your schedule by driving passengers around.</p>
                    </div>
                </div>

                <button id="btn-continue-role"
                    onclick="continueToRegister()"
                    disabled
                    class="w-full bg-[#1fbc55] text-black font-semibold rounded-xl py-3.5 transition duration-300 shadow-[0_0_15px_rgba(31,188,85,0.2)] disabled:opacity-40 disabled:cursor-not-allowed hover:bg-green-600">
                    Continue
                </button>

                <div class="text-center mt-6">
                    <p class="text-xs text-gray-500">Already have an account?
                        <a href="#" onclick="showView('login')" class="text-white hover:underline ml-1 font-medium">Sign in</a>
                    </p>
                </div>
            </div>

            <!-- ===== REGISTER VIEW ===== -->
            <div id="view-register" class="form-section hidden">
                <div class="flex items-center gap-3 mb-8">
                    <button onclick="showView('role')" class="text-gray-400 hover:text-white transition">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
                        </svg>
                    </button>
                    <div>
                        <h2 class="text-2xl font-semibold">Create your account</h2>
                        <p class="text-gray-400 text-xs mt-0.5">Signing up as a <span id="role-label" class="text-green-400 font-medium"></span></p>
                    </div>
                </div>

                <form class="space-y-5" id="register-form">
                    <div>
                        <label class="block text-xs font-medium text-gray-300 mb-2">Full Name</label>
                        <input type="text" id="reg-name" placeholder="Sarah Williams"
                            class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 transition text-sm text-gray-300">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-300 mb-2">Email Address</label>
                        <input type="email" id="reg-email" placeholder="sarah@example.com"
                            class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 transition text-sm text-gray-300">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-300 mb-2">Password</label>
                        <input type="password" id="reg-password" placeholder="••••••••"
                            class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 transition text-sm text-gray-300">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-300 mb-2">Phone</label>
                        <input type="number" id="reg-phone" placeholder="9846099985"
                            class="w-full bg-[#131418] border border-transparent rounded-xl px-4 py-3.5 focus:outline-none focus:border-green-500 transition text-sm text-gray-300">
                    </div>

                    <div class="pt-2">
                        <button type="submit" class="w-full bg-[#1fbc55] hover:bg-green-600 text-black font-semibold rounded-xl py-3.5 transition duration-300 shadow-[0_0_15px_rgba(31,188,85,0.2)]">
                            Register
                        </button>
                    </div>
                </form>

                <div class="text-center mt-6">
                    <p class="text-xs text-gray-500">Already have an account?
                        <a href="#" onclick="showView('login')" class="text-white hover:underline ml-1 font-medium">Sign in</a>
                    </p>
                </div>
            </div>

        </div>
    </div>
</body>

<script>
    const {z} = window.Zod 

    let selectedRole = null;

    // ── View switcher ──────────────────────────────────────────
    function showView(name) {
        ['login', 'role', 'register'].forEach(v => {
            const el = document.getElementById('view-' + v);
            if (v === name) {
                el.classList.remove('hidden');
                el.classList.add('form-section');
                // force reflow to retrigger animation
                void el.offsetWidth;
            } else {
                el.classList.add('hidden');
            }
        });
    }

    // ── ROLE SELECTION ─────────────────────────────────────────
    function selectRole(role) {
        selectedRole = role;
        document.getElementById('card-rider').classList.toggle('selected', role === 'rider');
        document.getElementById('card-driver').classList.toggle('selected', role === 'driver');
        document.getElementById('btn-continue-role').disabled = false;
    }

    function continueToRegister() {
        if (!selectedRole) return;
        document.getElementById('role-label').textContent = selectedRole === 'rider' ? '🧍 Rider' : '🚗 Driver';
        
        showView('register');
    }

    // ── Navigation links ───────────────────────────────────────
    document.getElementById('go-to-role-select').addEventListener('click', (e) => {
        e.preventDefault();
        showView('role');
    });

    // ── LOGIN ──────────────────────────────────────────────────
    document.getElementById('login-form').addEventListener('submit', function (e) {
        e.preventDefault();
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value.trim();
        if (!email || !password) {
            showError("Invalid email or password")
            return;
        }
        showSuccess("no worries buddy")
    });

    const registerSchema = z.object({
        name: z.string().min(3,"Name must be at least 3 characters"),
        email:z.string().email("Enter a valid email"),
        password:z.string().min(6,"Password must be at least 6 characters"),
        phone: z.string().regex(/^[6-9]\d{9}$/, "Invalid phone number")
    })

    let userLocation = null
    navigator.geolocation.getCurrentPosition(
        (position) => {
            userLocation = {
                lat: position.coords.latitude,
                lng: position.coords.longitude
            }
        },
        (error) => {
            showError("Location access denied")
        }
    )
    // ── REGISTER ───────────────────────────────────────────────
    document.getElementById('register-form').addEventListener('submit', async function (e) {
        e.preventDefault();
        const data = {
            name : document.getElementById('reg-name').value.trim(),
            email : document.getElementById('reg-email').value.trim(),
            password : document.getElementById('reg-password').value.trim(),
            phone : document.getElementById('reg-phone').value.trim(),
        }

        const frontEndValidation = registerSchema.safeParse(data)

        if(!frontEndValidation.success){

            const formattedMessage = Object.values(frontEndValidation.error.flatten().fieldErrors)
                .flat()
                .join(", ");
            showError(formattedMessage)
            return;
        }

        try{
            
            const res = await fetch('/auth/register',{
                method:"POST",
                headers:{
                    "Content-Type":"application/json"
                },
                body:JSON.stringify({
                    data:data,
                    role:selectedRole,
                    location:userLocation
                })
            })
            
            const result = await res.json()

            if(!result.success){
                showError(result.message)
                return;
            }

            showSuccess("നമസ്കാരം 🙏")
            window.location.href = result.redirect

        }catch(err){

            showError(err.message)
        }
    });

    
</script>

</html>